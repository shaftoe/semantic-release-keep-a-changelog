{
	"name": "@alexanderfortin/semantic-release-keep-a-changelog",
	"author": "Alexander Fortin",
	"version": "0.2.3",
	"description": "Opinionated semantic-release plugin that generates Keep a Changelog formatted CHANGELOG.md from conventional commits",
	"type": "module",
	"main": "./dist/index.js",
	"exports": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"package.json",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"scripts": {
		"build": "bun run validate && rm -rf dist && tsc --project tsconfig.build.json",
		"test": "bun test",
		"test:coverage": "bun test --coverage --coverage-reporter=lcov",
		"typecheck": "tsc --project tsconfig.check.json",
		"check": "biome check",
		"format": "biome check --write",
		"prepublishOnly": "tsc --project tsconfig.build.json",
		"validate": "bun run typecheck && bun run check",
		"release": "semantic-release",
		"release:dry-run": "semantic-release --dry-run"
	},
	"keywords": [
		"semantic-release",
		"changelog",
		"keep-a-changelog",
		"release-notes"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/shaftoe/semantic-release-keep-a-changelog"
	},
	"dependencies": {
		"@semantic-release/error": "^4.0.0",
		"conventional-changelog-writer": "8.4.0",
		"conventional-commits-filter": "^5.0.0",
		"conventional-commits-parser": "6.4.0",
		"get-stream": "9.0.1",
		"into-stream": "^9.1.0",
		"temporal-polyfill": "^0.3.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@semantic-release/commit-analyzer": "13.0.1",
		"@semantic-release/exec": "7.1.0",
		"@semantic-release/git": "10.0.1",
		"@semantic-release/github": "12.0.8",
		"@semantic-release/npm": "13.1.5",
		"@types/bun": "1.3.14",
		"@types/node": "25.9.1",
		"markdownlint": "^0.40.0",
		"semantic-release": "^25.0.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"semantic-release": ">=24.0.0"
	}
}
